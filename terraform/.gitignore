# Terraform state — contains sensitive data, never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variables — may contain secrets
terraform.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan
